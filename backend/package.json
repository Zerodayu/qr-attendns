{
  "name": "qr-attendnz-backend",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "dotenvx run -f .env.dev -- bun run --watch src/index.ts",
    "build": "dotenvx run -f .env.prod -- bun build src/index.ts --compile --outfile ./dist/server",
    "db:dev-gen": "bunx drizzle-kit generate --config=drizzle-dev.config.ts",
    "db:dev-push": "bunx drizzle-kit --config=drizzle-dev.config.ts push",
    "db:dev-mig": "bunx drizzle-kit --config=drizzle-dev.config.ts migrate",
    "db:dev-view": "bunx drizzle-kit --config=drizzle-dev.config.ts studio"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.75.0",
    "@electric-sql/pglite": "^0.5.3",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "module": "src/index.js"
}
